{
  "annotations": { "list": [] },
  "description": "NexusLog 存储层监控仪表板",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Elasticsearch 集群健康",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "max(elasticsearch_cluster_health_status{color=\"green\"}) * 100 + max(elasticsearch_cluster_health_status{color=\"yellow\"}) * 50",
          "legendFormat": "cluster health"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "Elasticsearch 写入速率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(elasticsearch_indices_indexing_index_total[5m])",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Redis 内存占用",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes / clamp_min(redis_memory_max_bytes, 1)",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      }
    },
    {
      "title": "PostgreSQL 连接占比",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count) by (instance) / clamp_min(sum(pg_settings_max_connections) by (instance), 1)",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      }
    },
    {
      "title": "Loki 日志摄入速率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(loki_distributor_bytes_received_total[5m]))",
          "legendFormat": "bytes/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["nexuslog", "storage"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "NexusLog 存储层监控",
  "uid": "nexuslog-storage"
}
