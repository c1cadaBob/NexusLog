# 监听端口与基础标识
HTTP_PORT=9091
AGENT_ID=collector-agent-node-01
AGENT_VERSION=0.1.3

# Pull API 鉴权（7.3）
AGENT_API_KEY_ACTIVE_ID=active
AGENT_API_KEY_ACTIVE=replace-with-strong-key
AGENT_API_KEY_NEXT_ID=next
AGENT_API_KEY_NEXT=

# 本地状态目录
CHECKPOINT_DIR=/var/lib/collector-agent/checkpoints
CACHE_DIR=/var/lib/collector-agent/cache

# 采集范围（7.6）
COLLECTOR_INCLUDE_PATHS=/var/**/*.log
COLLECTOR_CRITICAL_INCLUDE_PATHS=/var/log/messages,/var/log/secure,/var/log/cron,/var/log/maillog,/var/log/spooler
COLLECTOR_EXCLUDE_PATHS=/var/log/wtmp,/var/log/btmp
# 按路径注入自定义标签（JSON 数组，pattern 支持 glob）
COLLECTOR_PATH_LABEL_RULES=[{"pattern":"/var/log/nginx/*.log","labels":{"service":"nginx","env":"prod"}}]

# 可选：启用 Syslog 监听（用于网络设备 / Syslog 接入）
# 例如：[ {"protocol":"udp","bind":"0.0.0.0:5514"} ]
COLLECTOR_SYSLOG_LISTENERS_JSON=[]

# 控制面指标回传（建议启用，便于控制台显示真实 Agent 资源状态）
# install-release.sh 默认会根据 CONTROL_PLANE_BASE_URL 可达性写入 true/false。
CONTROL_PLANE_BASE_URL=http://127.0.0.1:8080
AGENT_METRICS_REPORT_ENABLED=true
AGENT_METRICS_REPORT_INTERVAL=30s
AGENT_METRICS_REPORT_TIMEOUT=10s

# 传输模式（默认被动拉取）
DELIVERY_MODE=pull
ENABLE_KAFKA_PIPELINE=false

# 如需切换为主动上传（Kafka 兼容），请改为：
# DELIVERY_MODE=dual
# ENABLE_KAFKA_PIPELINE=true
# 并补齐以下 Kafka / Schema Registry 参数
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_TOPIC=nexuslog.logs.raw
KAFKA_SCHEMA_REGISTRY_URL=http://127.0.0.1:18081
KAFKA_SCHEMA_SUBJECT=nexuslog.logs.raw-value
KAFKA_SCHEMA_FILE=/etc/nexuslog/contracts/log-raw.avsc
KAFKA_REQUIRED_ACKS=all
