# 监听端口与基础标识
HTTP_PORT=9091
AGENT_ID=collector-agent-node-01
AGENT_VERSION=0.1.0

# Pull API 鉴权（7.3）
AGENT_API_KEY_ACTIVE_ID=active
AGENT_API_KEY_ACTIVE=replace-with-strong-key
AGENT_API_KEY_NEXT_ID=next
AGENT_API_KEY_NEXT=

# 本地状态目录
CHECKPOINT_DIR=/var/lib/collector-agent/checkpoints
CACHE_DIR=/var/lib/collector-agent/cache

# 采集范围（7.6）
COLLECTOR_INCLUDE_PATHS=/var/log/*.log
COLLECTOR_EXCLUDE_PATHS=/var/log/wtmp,/var/log/btmp
# 按路径注入自定义标签（JSON 数组，pattern 支持 glob）
COLLECTOR_PATH_LABEL_RULES=[{"pattern":"/var/log/nginx/*.log","labels":{"service":"nginx","env":"prod"}}]

# 输出（Kafka / Schema Registry）
DELIVERY_MODE=dual
ENABLE_KAFKA_PIPELINE=true
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_TOPIC=nexuslog.logs.raw
KAFKA_SCHEMA_REGISTRY_URL=http://127.0.0.1:18081
KAFKA_SCHEMA_SUBJECT=nexuslog.logs.raw-value
KAFKA_SCHEMA_FILE=/etc/nexuslog/contracts/log-raw.avsc
KAFKA_REQUIRED_ACKS=all
