{
  "name": "@nexuslog/e2e-tests",
  "version": "0.1.0",
  "private": true,
  "description": "NexusLog E2E tests powered by Playwright",
  "scripts": {
    "test": "playwright test",
    "test:list": "playwright test --list",
    "test:list:chrome": "playwright test --config=playwright.chrome.config.js --list",
    "test:smoke": "playwright test tests/smoke.spec.js",
    "test:smoke:chrome": "playwright test --config=playwright.chrome.config.js tests/smoke.spec.js",
    "test:smoke:headed": "xvfb-run -a playwright test --headed tests/smoke.spec.js",
    "test:smoke:headed:chrome": "xvfb-run -a playwright test --headed --config=playwright.chrome.config.js tests/smoke.spec.js",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2"
  }
}
