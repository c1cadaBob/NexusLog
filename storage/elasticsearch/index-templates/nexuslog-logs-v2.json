{
  "index_patterns": ["nexuslog-logs-v2", "nexuslog-logs-v2-*"],
  "priority": 260,
  "data_stream": {},
  "template": {
    "settings": {
      "number_of_shards": 3,
      "number_of_replicas": 1,
      "refresh_interval": "5s",
      "codec": "best_compression",
      "index.lifecycle.name": "nexuslog-logs-ilm",
      "index.lifecycle.rollover_alias": "nexuslog-logs-v2"
    },
    "mappings": {
      "dynamic": true,
      "properties": {
        "@timestamp": { "type": "date", "format": "strict_date_optional_time||epoch_millis" },
        "message": {
          "type": "text",
          "fields": { "keyword": { "type": "keyword", "ignore_above": 1024 } }
        },
        "event_id": { "type": "keyword" },
        "source_collect_path": { "type": "keyword" },
        "batch_id": { "type": "keyword" },
        "schema_version": { "type": "keyword" },
        "tenant_id": { "type": "keyword" },
        "event": {
          "properties": {
            "id": { "type": "keyword" },
            "record_id": { "type": "keyword" },
            "sequence": { "type": "long" },
            "original": { "type": "text" },
            "kind": { "type": "keyword" },
            "category": { "type": "keyword" },
            "type": { "type": "keyword" },
            "severity": { "type": "short" }
          }
        },
        "log": {
          "properties": {
            "level": { "type": "keyword" },
            "offset": { "type": "long" },
            "file": {
              "properties": {
                "path": { "type": "keyword" },
                "name": { "type": "keyword" },
                "directory": { "type": "keyword" }
              }
            }
          }
        },
        "source": {
          "properties": {
            "kind": { "type": "keyword" },
            "path": { "type": "keyword" },
            "stream": { "type": "keyword" }
          }
        },
        "agent": {
          "properties": {
            "id": { "type": "keyword" },
            "version": { "type": "keyword" },
            "hostname": { "type": "keyword" },
            "ip": { "type": "ip" }
          }
        },
        "service": {
          "properties": {
            "name": { "type": "keyword" },
            "instance": { "properties": { "id": { "type": "keyword" } } },
            "version": { "type": "keyword" },
            "environment": { "type": "keyword" }
          }
        },
        "container": { "properties": { "name": { "type": "keyword" } } },
        "host": {
          "properties": {
            "name": { "type": "keyword" },
            "ip": { "type": "ip" }
          }
        },
        "process": {
          "properties": {
            "pid": { "type": "integer" },
            "thread": { "properties": { "id": { "type": "long" } } }
          }
        },
        "trace": { "properties": { "id": { "type": "keyword" } } },
        "span": { "properties": { "id": { "type": "keyword" } } },
        "request": { "properties": { "id": { "type": "keyword" } } },
        "user": { "properties": { "id": { "type": "keyword" } } },
        "http": {
          "properties": {
            "request": { "properties": { "method": { "type": "keyword" } } },
            "response": { "properties": { "status_code": { "type": "short" } } }
          }
        },
        "url": {
          "properties": {
            "path": { "type": "keyword" },
            "full": { "type": "keyword", "ignore_above": 4096 }
          }
        },
        "error": {
          "properties": {
            "type": { "type": "keyword" },
            "message": { "type": "text" },
            "stack_trace": { "type": "text" }
          }
        },
        "nexuslog": {
          "properties": {
            "transport": {
              "properties": {
                "batch_id": { "type": "keyword" },
                "channel": { "type": "keyword" },
                "compressed": { "type": "boolean" },
                "encrypted": { "type": "boolean" }
              }
            },
            "ingest": {
              "properties": {
                "received_at": { "type": "date", "format": "strict_date_optional_time||epoch_millis" },
                "schema_version": { "type": "keyword" },
                "pipeline_version": { "type": "keyword" },
                "parse_status": { "type": "keyword" },
                "parse_rule": { "type": "keyword" },
                "retry_count": { "type": "short" }
              }
            },
            "multiline": {
              "properties": {
                "enabled": { "type": "boolean" },
                "line_count": { "type": "integer" },
                "start_offset": { "type": "long" },
                "end_offset": { "type": "long" },
                "dropped_empty_prefix_lines": { "type": "integer" }
              }
            },
            "dedup": {
              "properties": {
                "fingerprint": { "type": "keyword" },
                "hit": { "type": "boolean" },
                "count": { "type": "integer" },
                "first_seen_at": { "type": "date", "format": "strict_date_optional_time||epoch_millis" },
                "last_seen_at": { "type": "date", "format": "strict_date_optional_time||epoch_millis" },
                "window_sec": { "type": "integer" },
                "strategy": { "type": "keyword" },
                "suppressed_count": { "type": "integer" }
              }
            },
            "governance": {
              "properties": {
                "tenant_id": { "type": "keyword" },
                "retention_policy": { "type": "keyword" },
                "pii_masked": { "type": "boolean" },
                "classification": { "type": "keyword" }
              }
            }
          }
        },
        "labels": { "type": "object", "dynamic": true }
      }
    }
  },
  "_meta": {
    "description": "NexusLog 结构化日志 v2 模板",
    "version": "2.0.0",
    "managed_by": "nexuslog-platform"
  }
}
