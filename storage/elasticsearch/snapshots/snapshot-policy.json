{
  "_comment": "NexusLog Elasticsearch 快照策略 | change_level: normal | 生效时间: 分钟级 | 方案A 默认适配 NAS 共享文件系统仓库",
  "policy_id": "nexuslog-snapshot-policy",
  "name": "<nexuslog-snapshot-{now/d}>",
  "schedule": "0 0 2 * * ?",
  "repository": "nexuslog-snapshots",
  "config": {
    "indices": ["nexuslog-logs-*", "nexuslog-alerts-*", "nexuslog-audit-*"],
    "ignore_unavailable": true,
    "include_global_state": false,
    "partial": false
  },
  "retention": {
    "expire_after": "30d",
    "min_count": 7,
    "max_count": 30
  },
  "repository_bootstrap": {
    "recommended_type": "fs",
    "recommended_location": "/usr/share/elasticsearch/snapshots",
    "install_script": "scripts/install-es-snapshot-repository.sh"
  }
}
