{
  "_comment": "NexusLog 审计快照策略 | change_level: cab | 生效时间: 分钟级 | 至少保留 1 年快照副本",
  "policy_id": "nexuslog-audit-snapshot-policy",
  "name": "<nexuslog-audit-snapshot-{now/d}>",
  "schedule": "0 0 3 * * ?",
  "repository": "nexuslog-snapshots",
  "config": {
    "indices": ["nexuslog-audit-*"],
    "ignore_unavailable": true,
    "include_global_state": false,
    "partial": false
  },
  "retention": {
    "expire_after": "400d",
    "min_count": 30,
    "max_count": 400
  },
  "repository_bootstrap": {
    "recommended_type": "fs",
    "recommended_location": "/usr/share/elasticsearch/snapshots",
    "install_script": "scripts/install-es-snapshot-repository.sh"
  }
}
