{
  "policy": {
    "phases": {
      "hot": {
        "min_age": "0ms",
        "actions": {
          "rollover": {
            "max_primary_shard_size": "20gb",
            "max_age": "7d",
            "max_docs": 50000000
          },
          "set_priority": {
            "priority": 95
          }
        }
      },
      "delete": {
        "min_age": "365d",
        "actions": {
          "wait_for_snapshot": {
            "policy": "nexuslog-audit-snapshot-policy"
          },
          "delete": {}
        }
      }
    }
  }
}
