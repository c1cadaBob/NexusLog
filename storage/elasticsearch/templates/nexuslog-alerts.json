{
  "_comment": "NexusLog 告警事件索引模板 | change_level: normal | 生效时间: 发布窗口",
  "_description": "定义告警事件数据的字段映射、生命周期和 rollover 写别名。",
  "index_patterns": ["nexuslog-alerts-*"],
  "priority": 210,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "refresh_interval": "1s",
      "codec": "best_compression",
      "index.lifecycle.name": "nexuslog-alerts-ilm",
      "index.lifecycle.rollover_alias": "nexuslog-alerts"
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date",
          "format": "strict_date_optional_time||epoch_millis"
        },
        "id": { "type": "keyword" },
        "alert_id": { "type": "keyword" },
        "tenant_id": { "type": "keyword" },
        "rule_id": { "type": "keyword" },
        "resource_threshold_id": { "type": "keyword" },
        "severity": { "type": "keyword" },
        "status": { "type": "keyword" },
        "title": { "type": "keyword" },
        "detail": { "type": "text" },
        "agent_id": { "type": "keyword" },
        "source_id": { "type": "keyword" },
        "fired_at": { "type": "date" },
        "resolved_at": { "type": "date" },
        "notified_at": { "type": "date" },
        "count": { "type": "integer" },
        "notification_result": {
          "type": "object",
          "dynamic": true
        }
      }
    }
  },
  "_meta": {
    "description": "NexusLog 告警事件索引模板",
    "version": "1.1.0",
    "change_level": "normal",
    "managed_by": "nexuslog-platform"
  }
}
