{
  "apiBaseUrl": "/api/v1",
  "wsBaseUrl": "/ws",
  "appName": "NexusLog",
  "version": "0.1.2",
  "features": {
    "enableWebSocket": true,
    "enableOfflineMode": false,
    "enableAnalytics": false
  },
  "theme": {
    "defaultMode": "light",
    "primaryColor": "#1890ff"
  },
  "session": {
    "idleTimeoutMinutes": 30,
    "refreshIntervalMinutes": 5
  },
  "collectorAgent": {
    "releaseProvider": "github",
    "owner": "c1cadabob",
    "repo": "NexusLog",
    "version": "v0.1.3",
    "releaseBaseUrl": "https://github.com/c1cadabob/NexusLog/releases/download/v0.1.3",
    "installScriptUrl": "https://github.com/c1cadabob/NexusLog/releases/download/v0.1.3/collector-agent-installer.sh",
    "containerImageProvider": "ghcr",
    "containerImage": "ghcr.io/c1cadabob/nexuslog-collector-agent:v0.1.3",
    "deliveryMode": "pull",
    "kafkaBrokers": "127.0.0.1:9092",
    "kafkaTopic": "nexuslog.logs.raw",
    "kafkaSchemaRegistryUrl": "http://127.0.0.1:18081",
    "kafkaSchemaSubject": "nexuslog.logs.raw-value",
    "kafkaRequiredAcks": "all"
  }
}
