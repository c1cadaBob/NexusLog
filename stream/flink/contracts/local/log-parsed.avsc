{
  "type": "record",
  "name": "LogParsed",
  "namespace": "com.nexuslog.contracts.local",
  "doc": "Flink 本地兼容解析日志 Schema（将 enum 降级为 string，便于 SQL/Table API 解码）",
  "fields": [
    {
      "name": "id",
      "type": "string",
      "doc": "日志唯一标识（UUID）"
    },
    {
      "name": "event_id",
      "type": ["null", "string"],
      "default": null,
      "doc": "统一事件 ID，与原始日志保持一致"
    },
    {
      "name": "timestamp",
      "type": {
        "type": "long",
        "logicalType": "timestamp-millis"
      },
      "doc": "日志原始时间戳（毫秒）"
    },
    {
      "name": "ingested_at",
      "type": {
        "type": "long",
        "logicalType": "timestamp-millis"
      },
      "doc": "日志入库时间戳（毫秒）"
    },
    {
      "name": "level",
      "type": "string",
      "doc": "日志级别（本地兼容模式）"
    },
    {
      "name": "source",
      "type": "string",
      "doc": "日志来源标识"
    },
    {
      "name": "service",
      "type": ["null", "string"],
      "default": null,
      "doc": "服务名称"
    },
    {
      "name": "stream",
      "type": ["null", "string"],
      "default": null,
      "doc": "日志流名称"
    },
    {
      "name": "message",
      "type": "string",
      "doc": "日志消息内容"
    },
    {
      "name": "fields",
      "type": {
        "type": "map",
        "values": "string"
      },
      "default": {},
      "doc": "解析后的结构化字段"
    },
    {
      "name": "attributes",
      "type": {
        "type": "map",
        "values": "string"
      },
      "default": {},
      "doc": "通用扩展属性"
    },
    {
      "name": "tags",
      "type": {
        "type": "map",
        "values": "string"
      },
      "default": {},
      "doc": "日志标签"
    },
    {
      "name": "schema_version",
      "type": ["null", "string"],
      "default": null,
      "doc": "解析链路 schema 版本"
    },
    {
      "name": "parse_status",
      "type": ["null", "string"],
      "default": null,
      "doc": "解析状态"
    },
    {
      "name": "trace_id",
      "type": ["null", "string"],
      "default": null,
      "doc": "分布式追踪 ID"
    },
    {
      "name": "span_id",
      "type": ["null", "string"],
      "default": null,
      "doc": "分布式追踪 Span ID"
    },
    {
      "name": "tenant_id",
      "type": ["null", "string"],
      "default": null,
      "doc": "租户 ID"
    }
  ]
}
