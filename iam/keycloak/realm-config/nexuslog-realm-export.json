{
  "_comment": "NexusLog Keycloak Realm 完整导入配置，整合 realm、clients、roles、mappers",
  "id": "nexuslog",
  "realm": "nexuslog",
  "displayName": "NexusLog",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "failureFactor": 5,
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "passwordPolicy": "length(8) and upperCase(1) and lowerCase(1) and digits(1) and specialChars(1)",
  "eventsEnabled": true,
  "eventsExpiration": 2592000,
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true,
  "internationalizationEnabled": true,
  "supportedLocales": ["en", "zh-CN"],
  "defaultLocale": "zh-CN",
  "loginTheme": "nexuslog",
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "系统管理员，拥有所有权限",
        "composite": true,
        "composites": {
          "realm": ["user-manager", "log-viewer", "alert-manager", "audit-viewer", "config-manager"]
        }
      },
      { "name": "user-manager", "description": "用户管理员" },
      { "name": "log-viewer", "description": "日志查看者" },
      { "name": "alert-manager", "description": "告警管理员" },
      { "name": "audit-viewer", "description": "审计查看者" },
      { "name": "config-manager", "description": "配置管理员" }
    ]
  },
  "clients": [
    {
      "clientId": "nexuslog-frontend",
      "name": "NexusLog Frontend Console",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "rootUrl": "${FRONTEND_URL}",
      "redirectUris": ["${FRONTEND_URL}/*"],
      "webOrigins": ["${FRONTEND_URL}"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "${FRONTEND_URL}/*"
      }
    },
    {
      "clientId": "nexuslog-api",
      "name": "NexusLog API Service",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "secret": "${API_CLIENT_SECRET}",
      "redirectUris": [],
      "webOrigins": []
    }
  ],
  "identityProviders": [],
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "enabled": true,
      "defaultAction": false
    },
    {
      "alias": "UPDATE_PASSWORD",
      "name": "Update Password",
      "enabled": true,
      "defaultAction": false
    },
    {
      "alias": "VERIFY_EMAIL",
      "name": "Verify Email",
      "enabled": true,
      "defaultAction": false
    }
  ]
}
